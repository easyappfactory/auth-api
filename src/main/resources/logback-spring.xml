<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="project.logging.env" source="project.logging.env" defaultValue="alpha"/>
    <include resource="base-logback.xml"/>

    <springProfile name="alpha,prod">
        <root level="INFO">
            <appender-ref ref="JSON_STDOUT"/>
        </root>
        <!-- 개발자 코드: trace 포함 전부 출력 -->
        <logger name="com.wq.auth" level="TRACE"/>
        <!-- 프레임워크 노이즈 억제 -->
        <logger name="org.hibernate" level="WARN"/>
        <logger name="com.zaxxer.hikari" level="WARN"/>
        <logger name="org.springframework.boot.autoconfigure" level="WARN"/>
        <logger name="org.springframework.boot.web" level="WARN"/>
        <logger name="org.springframework.data" level="WARN"/>
        <logger name="org.springframework.orm" level="WARN"/>
        <logger name="org.springframework.web" level="WARN"/>
        <logger name="org.springframework.security" level="WARN"/>
    </springProfile>
</configuration>
